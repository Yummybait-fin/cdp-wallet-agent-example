          ]
        },
        {
          "type": "evmData",
          "abi": "erc20",
          "conditions": [
            {
              "function": "approve",
              "params": [
                {
                  "name": "spender",
                  "operator": "in",
                  "values": ["0x03a520b32C04BF3bEEf7BEb72E919cf822Ed34f1"]
                }
              ]
            }
          ]
        }
      ]
    }
