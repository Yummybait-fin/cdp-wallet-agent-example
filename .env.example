# Sourced before you ask the agent to poll (`source .env`), and read by
# docker-compose for the MCP services. Everything else lives in config/*.json.

# YummyBait signals API + your per-user key (used by the poll curl in the
# yummybait-signals skill).
YBT_API_URL=http://localhost:8080
YBT_SIGNALS_KEY=ybt_live_xxx

# Coinbase CDP — needed for the cdp MCP (act mode). Register a project at
# https://portal.cdp.coinbase.com/ → create a Secret API Key (id + secret) and a
# Wallet Secret. Bound by the CDP Wallet Policy you apply (README "Apply the CDP policy").
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# What to manage and how lives in (edit these, not code):
#   STRATEGY.md           — plain-English intent
#   config/wallets.json   — addresses to watch
#   config/rules.json     — CEL signal rules (the agent can tune these)
#   config/policy.json    — mode (observe/act) + caps + allowed actions/chains
